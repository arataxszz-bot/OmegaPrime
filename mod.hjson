# the mod name as displayed in-game
displayName: "Omega Prime AI Commander"
# the internal name of your mod
name: "omega-prime-ai"
# your name
author: "OpenAI"
# the fully qualified main class of the mod
main: "omega.OmegaPrimeMod"
# the mod description as seen in the mod dialog
description: "Command & Conquer style Omega Prime control layer with adaptive AI, swarm logic, overmind UI, mobile HUD, and persistent settings."
# the mod version
version: 2.0.0
# the minimum game build required to run this mod
minGameVersion: 158
# this is a java mod
java: true
